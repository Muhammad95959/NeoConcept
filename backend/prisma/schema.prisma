generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  ADMIN
  INSTRUCTOR
  STUDENT
  ASSISTANT
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}

enum MeetingStatus {
  SCHEDULED
  LIVE
  ENDED
}

enum MeetingRole {
  HOST
  PARTICIPANT
}

// ============================================================
// USER
// ============================================================

model User {
  id                   String    @id @default(uuid())
  createdAt            DateTime  @default(now())
  deletedAt            DateTime?
  email                String
  username             String
  password             String?
  googleId             String?   @unique
  role                 Role
  emailConfirmed       Boolean   @default(false)
  confirmEmailToken    String?
  confirmEmailExpires  DateTime?
  resetPasswordOTP     String?
  resetPasswordExpires DateTime?
  passwordChangedAt    DateTime?
  otpAttempts          Int       @default(0)

  posts               Post[]           @relation("UserPosts")
  resources           Resource[]       @relation("UserResources")
  comments            Comment[]
  staffRequests       StaffRequest[]
  studentRequests     StudentRequest[]
  courseUsers         UserCourse[]
  createdTrack        Track?           @relation("TrackCreator")
  userTracks          UserTrack[]
  hostedMeetings      Meeting[]        @relation("HostRelation")
  meetingParticipants Participant[]

  @@map("users")
}

// ============================================================
// TRACK
// ============================================================

model Track {
  id               String    @id @default(uuid())
  createdAt        DateTime  @default(now())
  deletedAt        DateTime?
  creatorId        String?   @unique
  name             String
  domain           String?
  language         String?
  level            String?
  shortDescription String?
  longDescription  String?
  targetAudience   String?
  pricingModel     String?
  learningOutcomes String[]
  relatedJobs      String[]

  creator    User?       @relation("TrackCreator", fields: [creatorId], references: [id])
  courses    Course[]
  userTracks UserTrack[]

  @@map("tracks")
}

model UserTrack {
  userId    String
  trackId   String
  joinedAt  DateTime  @default(now())
  deletedAt DateTime?

  user  User  @relation(fields: [userId], references: [id])
  track Track @relation(fields: [trackId], references: [id])

  @@id([userId, trackId])
  @@map("user_tracks")
}

// ============================================================
// COURSE
// ============================================================

model Course {
  id          String    @id @default(uuid())
  createdAt   DateTime  @default(now())
  deletedAt   DateTime?
  trackId     String
  name        String
  description String?
  protected   Boolean   @default(true)

  track           Track                @relation(fields: [trackId], references: [id])
  prerequisites   CoursePrerequisite[] @relation("CourseToPrerequisite")
  requiredFor     CoursePrerequisite[] @relation("PrerequisiteToCourse")
  courseUsers     UserCourse[]
  staffRequests   StaffRequest[]
  studentRequests StudentRequest[]
  posts           Post[]
  resources       Resource[]
  meetings        Meeting[]

  @@map("courses")
}

model CoursePrerequisite {
  courseId       String
  prerequisiteId String

  course       Course @relation("CourseToPrerequisite", fields: [courseId], references: [id])
  prerequisite Course @relation("PrerequisiteToCourse", fields: [prerequisiteId], references: [id])

  @@id([courseId, prerequisiteId])
  @@map("course_prerequisites")
}

model UserCourse {
  userId       String
  courseId     String
  roleInCourse Role
  joinedAt     DateTime  @default(now())
  deletedAt    DateTime?

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@id([userId, courseId])
  @@map("user_courses")
}

// ============================================================
// REQUESTS
// ============================================================

model StaffRequest {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  userId    String
  courseId  String
  message   String?
  status    Status   @default(PENDING)

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@map("staff_requests")
}

model StudentRequest {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  userId    String
  courseId  String
  message   String?
  status    Status   @default(PENDING)

  user   User   @relation(fields: [userId], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@map("student_requests")
}

// ============================================================
// CONTENT
// ============================================================

model Post {
  id         String   @id @default(uuid())
  createdAt  DateTime @default(now())
  courseId   String
  uploadedBy String
  title      String
  content    String

  user     User      @relation("UserPosts", fields: [uploadedBy], references: [id])
  course   Course    @relation(fields: [courseId], references: [id])
  comments Comment[]

  @@map("posts")
}

model Comment {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  postId    String
  userId    String
  content   String

  user User @relation(fields: [userId], references: [id])
  post Post @relation(fields: [postId], references: [id])

  @@index([postId])
  @@map("comments")
}

model Resource {
  id         String   @id @default(uuid())
  uploadedAt DateTime @default(now())
  courseId   String
  uploadedBy String
  fileName   String
  fileType   String
  fileUrl    String
  fileKey    String

  user   User   @relation("UserResources", fields: [uploadedBy], references: [id])
  course Course @relation(fields: [courseId], references: [id])

  @@map("resources")
}

// ============================================================
// MEETINGS
// ============================================================

model Meeting {
  id          String        @id @default(uuid())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  hostId      String
  courseId    String
  channelName String        @unique
  title       String
  scheduledAt DateTime?
  status      MeetingStatus @default(SCHEDULED)

  host         User          @relation("HostRelation", fields: [hostId], references: [id])
  course       Course        @relation(fields: [courseId], references: [id])
  participants Participant[]

  @@map("meetings")
}

model Participant {
  id        String      @id @default(uuid())
  meetingId String
  userId    String
  role      MeetingRole

  user    User    @relation(fields: [userId], references: [id])
  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@unique([userId, meetingId])
  @@map("participants")
}
