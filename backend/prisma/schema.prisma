generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String           @id @default(uuid())
  createdAt            DateTime         @default(now())
  email                String
  username             String
  password             String?
  googleId             String?          @unique
  role                 Role
  emailConfirmed       Boolean          @default(false)
  confirmEmailToken    String?
  confirmEmailExpires  DateTime?
  resetPasswordOTP     String?
  resetPasswordExpires DateTime?
  passwordChangedAt    DateTime?
  deletedAt            DateTime?
  currentTrackId       String?
  otpAttempts          Int              @default(0)
  Post                 Post[]
  Resources            Resource[]
  staffRequests        StaffRequest[]
  studentRequests      StudentRequest[]
  createdTrack         Track?           @relation("TrackCreator")
  courseUsers          UserCourse[]
  userTracks           UserTrack[]
  currentTrack         Track?           @relation("UserTrack", fields: [currentTrackId], references: [id])
  participants         Participant[]
  hostedMeetings      Meeting[]        @relation("MeetingHost")

  @@map("users")
}

model Track {
  id               String      @id @default(uuid())
  name             String
  createdAt        DateTime    @default(now())
  deletedAt        DateTime?
  creatorId        String?     @unique
  domain           String?
  language         String?
  learningOutcomes String[]
  level            String?
  longDescription  String?
  pricingModel     String?
  relatedJobs      String[]
  shortDescription String?
  targetAudience   String?
  courses          Course[]
  creator          User?       @relation("TrackCreator", fields: [creatorId], references: [id])
  userTracks       UserTrack[]
  users            User[]      @relation("UserTrack")

  @@map("tracks")
}

model UserTrack {
  userId    String
  trackId   String
  joinedAt  DateTime  @default(now())
  deletedAt DateTime?
  track     Track     @relation(fields: [trackId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@id([userId, trackId])
  @@map("user_tracks")
}

model Course {
  id              String           @id @default(uuid())
  name            String
  description     String?
  createdAt       DateTime         @default(now())
  trackId         String
  deletedAt       DateTime?
  protected       Boolean          @default(true)
  track           Track            @relation(fields: [trackId], references: [id])
  Post            Post[]
  Resources       Resource[]
  staffRequests   StaffRequest[]
  studentRequests StudentRequest[]
  courseUsers     UserCourse[]

  @@map("courses")
}

model UserCourse {
  userId       String
  courseId     String
  roleInCourse Role
  joinedAt     DateTime  @default(now())
  deletedAt    DateTime?
  course       Course    @relation(fields: [courseId], references: [id])
  user         User      @relation(fields: [userId], references: [id])

  @@id([userId, courseId])
  @@map("user_courses")
}

model StaffRequest {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  message   String?
  status    Status   @default(PENDING)
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@map("staff_requests")
}

model StudentRequest {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  status    Status   @default(PENDING)
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@map("student_requests")
}

model Resource {
  id         String   @id @default(uuid())
  uploadedBy String
  courseId   String
  uploadedAt DateTime @default(now())
  fileName   String
  fileType   String
  fileUrl    String
  fileKey    String
  course     Course   @relation(fields: [courseId], references: [id])
  user       User     @relation(fields: [uploadedBy], references: [id])

  @@map("resources")
}

model Post {
  id         String   @id @default(uuid())
  uploadedBy String
  courseId   String
  title      String
  content    String
  createdAt  DateTime @default(now())
  course     Course   @relation(fields: [courseId], references: [id])
  user       User     @relation(fields: [uploadedBy], references: [id])

  @@map("posts")
}

enum Role {
  ADMIN
  INSTRUCTOR
  STUDENT
  ASSISTANT
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}

enum MeetingStatus {
  SCHEDULED
  LIVE
  ENDED
}

enum ParticipantRole {
  HOST
  PARTICIPANT
}

model Meeting {
  id          String          @id @default(uuid())
  title       String
  channelName String
  status      MeetingStatus   @default(SCHEDULED)
  scheduledAt DateTime?
  createdAt   DateTime        @default(now())
  hostId      String
  host        User            @relation("MeetingHost", fields: [hostId], references: [id])
  participants Participant[]

  @@map("meetings")
}

model Participant {
  userId    String
  meetingId String
  role      ParticipantRole  @default(PARTICIPANT)
  joinedAt  DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id])
  meeting   Meeting          @relation(fields: [meetingId], references: [id])

  @@id([userId, meetingId])
  @@map("participants")
}
