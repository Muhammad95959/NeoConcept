generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String           @id @default(uuid())
  createdAt            DateTime         @default(now())
  email                String
  username             String
  password             String?
  googleId             String?          @unique
  role                 Role
  emailConfirmed       Boolean          @default(false)
  confirmEmailToken    String?
  confirmEmailExpires  DateTime?
  resetPasswordOTP     String?
  resetPasswordExpires DateTime?
  passwordChangedAt    DateTime?
  deletedAt            DateTime?
  currentTrackId       String?
  Post                 Post[]
  Resources            Resource[]
  staffRequests        StaffRequest[]
  studentRequests      StudentRequest[]
  createdTrack         Track?           @relation("TrackCreator")
  courseUsers          UserCourse[]
  userTracks           UserTrack[]
  currentTrack         Track?           @relation("UserTrack", fields: [currentTrackId], references: [id])

  @@map("users")
}

model Track {
  id               String      @id @default(uuid())
  name             String
  createdAt        DateTime    @default(now())
  deletedAt        DateTime?
  creatorId        String?     @unique
  domain           String?
  language         String?
  learningOutcomes String[]
  level            String?
  longDescription  String?
  pricingModel     String?
  relatedJobs      String[]
  shortDescription String?
  targetAudience   String?
  courses          Course[]
  creator          User?       @relation("TrackCreator", fields: [creatorId], references: [id])
  userTracks       UserTrack[]
  users            User[]      @relation("UserTrack")

  @@map("tracks")
}

model UserTrack {
  userId    String
  trackId   String
  joinedAt  DateTime  @default(now())
  deletedAt DateTime?
  track     Track     @relation(fields: [trackId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@id([userId, trackId])
  @@map("user_tracks")
}

model Course {
  id                                                                String                 @id @default(uuid())
  name                                                              String
  description                                                       String?
  createdAt                                                         DateTime               @default(now())
  trackId                                                           String
  deletedAt                                                         DateTime?
  protected                                                         Boolean                @default(true)
  course_prerequisites_course_prerequisites_courseIdTocourses       course_prerequisites[] @relation("course_prerequisites_courseIdTocourses")
  course_prerequisites_course_prerequisites_prerequisiteIdTocourses course_prerequisites[] @relation("course_prerequisites_prerequisiteIdTocourses")
  track                                                             Track                  @relation(fields: [trackId], references: [id])
  Post                                                              Post[]
  Resources                                                         Resource[]
  staffRequests                                                     StaffRequest[]
  studentRequests                                                   StudentRequest[]
  courseUsers                                                       UserCourse[]

  @@map("courses")
}

model UserCourse {
  userId       String
  courseId     String
  roleInCourse Role
  joinedAt     DateTime  @default(now())
  deletedAt    DateTime?
  course       Course    @relation(fields: [courseId], references: [id])
  user         User      @relation(fields: [userId], references: [id])

  @@id([userId, courseId])
  @@map("user_courses")
}

model StaffRequest {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  message   String?
  status    Status   @default(PENDING)
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@map("staff_requests")
}

model StudentRequest {
  id        String   @id @default(uuid())
  userId    String
  courseId  String
  status    Status   @default(PENDING)
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@map("student_requests")
}

model Resource {
  id         String   @id @default(uuid())
  uploadedBy String
  courseId   String
  uploadedAt DateTime @default(now())
  fileName   String
  fileType   String
  fileUrl    String
  fileKey    String
  course     Course   @relation(fields: [courseId], references: [id])
  user       User     @relation(fields: [uploadedBy], references: [id])

  @@map("resources")
}

model Post {
  id         String   @id @default(uuid())
  uploadedBy String
  courseId   String
  title      String
  content    String
  createdAt  DateTime @default(now())
  course     Course   @relation(fields: [courseId], references: [id])
  user       User     @relation(fields: [uploadedBy], references: [id])

  @@map("posts")
}

model course_prerequisites {
  courseId                                             String
  prerequisiteId                                       String
  courses_course_prerequisites_courseIdTocourses       Course @relation("course_prerequisites_courseIdTocourses", fields: [courseId], references: [id])
  courses_course_prerequisites_prerequisiteIdTocourses Course @relation("course_prerequisites_prerequisiteIdTocourses", fields: [prerequisiteId], references: [id])

  @@id([courseId, prerequisiteId])
}

enum Role {
  ADMIN
  INSTRUCTOR
  STUDENT
  ASSISTANT
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}
